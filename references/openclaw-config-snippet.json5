// dinomem — OpenClaw config reference
// Add/merge these blocks into your ~/.openclaw/openclaw.json
// The install.sh script patches these automatically.
// Manual reference if you prefer to configure by hand.

{
  // Session reset: idle-based 7 days (not daily)
  // Prevents premature resets for active agents.
  // auto_session_reset.py handles memory-aware resets independently.
  session: {
    reset: {
      mode: "idle",
      idleMinutes: 10080,  // 7 days
    },
  },

  models: {
    providers: {
      // TEI embedding server (sentence-transformers, local Docker)
      "tei-embed": {
        api: "openai",
        baseUrl: "http://localhost:8080/v1",
        apiKey: "dummy",  // TEI does not require auth
        models: [{ id: "sentence-transformers/all-MiniLM-L6-v2" }],
      },
    },
  },

  agents: {
    defaults: {
      // Disable TTL-based context pruning.
      // TTL pruning drops messages by age (blunt) — bad for continuity.
      // Let compaction handle context management instead (summarizes before dropping).
      contextPruning: {
        mode: "off",
      },

      // Compaction: safeguard mode
      // Triggers when: contextTokens > contextWindow - reserveTokens
      // e.g. for 200k window: triggers at 150k active tokens
      compaction: {
        mode: "safeguard",
        // Rotate session file after compaction — prevents unbounded file growth.
        // Old file stays on disk for memory extraction; new file starts from summary + tail.
        truncateAfterCompaction: false,
        memoryFlush: {
          enabled: false,
          softThresholdTokens: 10000,
          // model: memoryFlush is also a NO-REASONING bulk task (reads the session
          // tail, writes the bare daily memory/YYYY-MM-DD.md) — same tier as
          // compaction.model below. Pin it to the SAME cheap, high-context model.
          // Override is exact (does not inherit the session fallback chain).
          // Unset = your live session model is used (works, just costs more).
          //   model: "your-provider/your-cheap-high-context-model",
        },
        // reserveTokens: set this to keep active context below ~200k tokens.
        // Formula: reserveTokens = max(0, contextWindow - 200000)
        // Why 200k? Three reasons:
        //   1. Context bloat — compaction triggers early, before the session is too
        //      full to recover. Prevents the compaction-overflow death spiral.
        //   2. Response speed — inference slows non-linearly above ~200k active tokens.
        //      Keeping context lean = faster TTFT regardless of model window size.
        //   3. Memory quality — compaction summaries are tighter and higher-signal
        //      when the session is lean. A session at 180k tokens produces a noisier
        //      summary than one at 50k. Cleaner summaries = better extract_memory.py output.
        // Examples:
        //   200k model (Claude Sonnet, Gemini) → reserveTokens: 50000
        //   1M model (Gemini 1.5 Pro)          → reserveTokens: 800000
        //   128k model                          → reserveTokens: 0  (already under limit)
        // Not patched by install.sh — set manually based on your model.
        //   reserveTokens: 50000,
        //   keepRecentTokens: 32000, // tokens preserved after each compaction
        //
        // model: compaction is a NO-REASONING bulk task (summarizing context) —
        // same tier as dinomem's extract_memory / memory_review. Use the SAME
        // cheap, high-context model you set for DINOMEM_CHEAP_MODEL. Unset = your
        // default model is used (works, just costs more). Not auto-set — the right
        // model depends entirely on what you have.
        //   model: "your-provider/your-cheap-high-context-model",
      },

      // Root files (AGENTS.md, SOUL.md, TOOLS.md, etc) injected every turn.
      // Without this, OpenClaw may skip injection on continuation turns.
      // NOTE: the valid key is `contextInjection` (already defaults to "always").
      // Do NOT use `workspaceBootstrap` — it is not a valid OpenClaw config key and
      // will crash the gateway (agents.defaults is additionalProperties:false).
      contextInjection: "always",

      // Memory search via local TEI embedding server
      memorySearch: {
        provider: "openai-compatible",
        model: "sentence-transformers/all-MiniLM-L6-v2",
        remote: {
          baseUrl: "http://localhost:8080/v1",
        },
        // Hybrid search: 70% vector + 30% text (BM25-style)
        query: {
          hybrid: {
            vectorWeight: 0.7,
            textWeight: 0.3,
          },
        },
      },
    },
  },
}
